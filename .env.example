# Flask Configuration
FLASK_ENV=production

# Database (leave empty for SQLite, or use PostgreSQL connection string)
DATABASE_URL=

# JWT & Security
JWT_SECRET_KEY=your_secure_jwt_secret_key_here

# Roboflow API
ROBOFLOW_API_KEY=your_roboflow_api_key
ROBOFLOW_MODEL_ID=crop-disease-2rilx
ROBOFLOW_MODEL_VERSION=4
ROBOFLOW_CROP_MODEL_ID=
ROBOFLOW_CROP_MODEL_VERSION=1

# AgroMonitoring API
AGROMONITORING_API_KEY=your_agromonitoring_api_key

# Email Configuration (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_SENDER_NAME=Mhenga Bot
MAIL_SENDER_EMAIL=your_email@gmail.com
